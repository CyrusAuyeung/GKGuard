{
  "name": "gkguard-desktop",
  "version": "0.1.20",
  "description": "GKGuard campus security AI dashboard desktop shell.",
  "main": "desktop/main.js",
  "author": "GKGuard Team",
  "private": true,
  "scripts": {
    "desktop": "electron .",
    "desktop:dev": "electron . --devtools",
    "pack": "electron-builder --win --x64 --dir",
    "dist": "electron-builder --win --x64 --publish never",
    "test:backend": "cd backend && python -m pytest"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.gkguard.desktop",
    "productName": "GKGuard",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "CyrusAuyeung",
        "repo": "GKGuard"
      }
    ],
    "artifactName": "GKGuard-Setup-${version}.${ext}",
    "icon": "desktop/assets/icons/app-mark.ico",
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-dist/gkguard-backend",
        "to": "backend-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "app/**/*",
          "data/**/*",
          "requirements.txt",
          "pytest.ini"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ssh2": "^1.17.0"
  }
}
