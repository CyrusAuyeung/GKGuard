{
  "name": "gkguard-desktop",
  "version": "0.1.34",
  "description": "GKGuard campus security AI dashboard desktop shell.",
  "main": "desktop/main.js",
  "author": "GKGuard Team",
  "private": true,
  "scripts": {
    "desktop": "electron .",
    "desktop:dev": "electron . --devtools",
    "pack": "npm run pack:win",
    "pack:win": "electron-builder --win --x64 --dir",
    "pack:mac": "electron-builder --mac --x64 --dir",
    "pack:linux": "electron-builder --linux --x64 --dir",
    "dist": "npm run dist:win",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:mac": "electron-builder --mac --x64 --publish never",
    "dist:linux": "electron-builder --linux --x64 --publish never",
    "test:backend": "cd backend && python -m pytest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.gkguard.desktop",
    "productName": "GKGuard",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "CyrusAuyeung",
        "repo": "GKGuard"
      }
    ],
    "artifactName": "GKGuard-${os}-${arch}-${version}.${ext}",
    "icon": "desktop/assets/icons/app-mark.png",
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-dist/gkguard-backend",
        "to": "backend-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "app/**/*",
          "data/**/*",
          "requirements.txt",
          "pytest.ini"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "GKGuard-Setup-${version}.${ext}",
      "icon": "desktop/assets/icons/app-mark.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "GKGuard-macOS-${arch}-${version}.${ext}",
      "category": "public.app-category.productivity",
      "icon": "desktop/assets/icons/app-mark.icns",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "GKGuard-Linux-${arch}-${version}.${ext}",
      "category": "Utility",
      "icon": "desktop/assets/icons/app-mark.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ssh2": "^1.17.0"
  }
}
