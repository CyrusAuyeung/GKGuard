APP_NAME="CampusVision C1"
APP_HOST=127.0.0.1
APP_PORT=8000

# Required automatically when APP_HOST or the uvicorn host is 0.0.0.0 / ::.
# Leave empty only for local loopback development.
CAMPUSVISION_API_KEY=
C1_API_KEY=
CAMPUSVISION_REQUIRE_API_KEY=false

CAMPUSVISION_DATA_DIR=data

# Production face engine. Only InsightFace/ArcFace is supported.
FACE_ENGINE=insightface
INSIGHTFACE_DET_SIZE=960
INSIGHTFACE_ENGINE_POOL_SIZE=1
INSIGHTFACE_MAX_CONCURRENT_INFERENCES=1

DEFAULT_FRAME_INTERVAL_SEC=1.0

# Upload and indexing limits.
CAMPUSVISION_MAX_QUERY_IMAGE_UPLOAD_BYTES=16777216
CAMPUSVISION_MAX_QUERY_IMAGES=5
CAMPUSVISION_MAX_VIDEO_UPLOAD_BYTES=536870912
CAMPUSVISION_MAX_INDEX_FRAMES=5000

# Person observation and event aggregation.
EVENT_TIME_WINDOW_SEC=10.0
ENABLE_EVENT_PERSISTENCE=true
EVENT_PERSISTENCE_MODE=async
EVENT_BUILD_WORKER_COUNT=1
SERIALIZE_LIVE_ANALYSIS=false
ENABLE_POST_INDEX_MEMORY_CLEANUP=true
POST_INDEX_MEMORY_CLEANUP_INTERVAL=6

# First body-detection backend. This is intentionally replaceable by an ONNX detector later.
ENABLE_BODY_DETECTION=true
BODY_DETECTION_BACKEND=opencv_hog
BODY_DETECTION_FRAME_STRIDE=2
PERSON_DETECTION_CONFIDENCE_THRESHOLD=0.35
PERSON_DETECTION_NMS_THRESHOLD=0.45
ULTRALYTICS_MODEL_PATH=data/models/ultralytics/yolo11x.pt
ULTRALYTICS_DEVICE=cuda:0
ULTRALYTICS_IMGSZ=960
ULTRALYTICS_MAX_DETECTIONS=50
MIN_PERSON_BOX_WIDTH=28
MIN_PERSON_BOX_HEIGHT=56
MAX_BBOX_EDGE_TRUNCATION_RATIO=0.35
FACE_BODY_MATCH_THRESHOLD=0.35
FACE_BODY_MAX_NORMALIZED_DISTANCE=0.65

# Clothing color extraction from visible body regions.
ENABLE_CLOTHING_DETECTION=true
ENABLE_UPPER_CLOTHING_DETECTION=true
ENABLE_LOWER_CLOTHING_DETECTION=true
ENABLE_LOWER_CLOTHING_CORE=false
CLOTHING_ANALYSIS_FRAME_STRIDE=2
UPPER_ROI_START_RATIO=0.20
UPPER_ROI_END_RATIO=0.50
LOWER_ROI_START_RATIO=0.46
LOWER_ROI_END_RATIO=0.78
UPPER_COLOR_CONFIDENCE_THRESHOLD=0.35
LOWER_COLOR_CONFIDENCE_THRESHOLD=0.35
MIN_CLOTHING_COLOR_CONFIDENCE=0.60
CLOTHING_ROI_CENTER_WIDTH_RATIO=0.58
LOWER_BODY_MIN_DETECTION_CONFIDENCE=0.45
MIN_VALID_PIXEL_RATIO=0.18
MIN_CLOTHING_ROI_AREA=300
CLOTHING_COLOR_LABELS=black,white,gray,red,orange,yellow,green,blue,purple,brown,pink,striped,other,unknown
CLOTHING_MODEL_VERSION=hsv_roi_v6_upper_lab_guard_striped
ENABLE_UPPER_COLOR_CALIBRATOR=false
# Calibrator models must carry deployment_allowed=true and must not be trained
# from manual eval labels. Manual check data is eval-only.
UPPER_COLOR_CALIBRATOR_PATH=data/models/clothing/upper_color_calibrator_v1.json
UPPER_COLOR_CALIBRATOR_K=1
UPPER_COLOR_CALIBRATOR_MIN_CONFIDENCE=0.0

# Online upper-color backend. Set UPPER_COLOR_BACKEND=clip_schp to use
# H/14 + SCHP + profile_realtime_balanced_prompt_v2.
# The CLIP backend emits lower softmax scores than the HSV heuristic, so use
# UPPER_COLOR_CONFIDENCE_THRESHOLD=0.09 when enabling this candidate path.
UPPER_COLOR_BACKEND=hsv
UPPER_COLOR_CLIP_BACKEND=hf
UPPER_COLOR_CLIP_MODEL_DIR=data/models/clip/laion_CLIP-ViT-H-14-laion2B-s32B-b79K
UPPER_COLOR_CLIP_DEVICE=cuda:0
UPPER_COLOR_CLIP_PROFILE=profile_realtime_balanced_prompt_v2
UPPER_COLOR_CLIP_TEMPERATURE=10.0
UPPER_COLOR_CLIP_MIN_CONFIDENCE=0.0
UPPER_COLOR_CLIP_FAIL_OPEN=true
ENABLE_UPPER_COLOR_BACKEND_FOR_FACE_ESTIMATED_BODY=false
UPPER_COLOR_SCHP_ROOT=data/models/schp/Self-Correction-Human-Parsing
UPPER_COLOR_SCHP_CHECKPOINT=data/models/schp/checkpoints/schp/exp-schp-201908261155-lip.pth
UPPER_COLOR_SCHP_MIN_MASK_PIXELS=250
UPPER_COLOR_TEMPORAL_CACHE_FACE_MAX_AGE_SEC=30.0
UPPER_COLOR_TEMPORAL_CACHE_FACE_SIMILARITY_THRESHOLD=0.62

# Appearance sessions are short-term clothing profiles, not permanent person attributes.
APPEARANCE_SESSION_MAX_GAP_SEC=14400
APPEARANCE_SESSION_MIN_SUPPORT=2
APPEARANCE_SESSION_PROFILE_CONFIDENCE=0.58
APPEARANCE_SESSION_LOW_CONFIDENCE_THRESHOLD=0.55
APPEARANCE_SESSION_CHANGE_CONFIDENCE=0.82
