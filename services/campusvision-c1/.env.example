APP_NAME="CampusVision C1"
APP_HOST=127.0.0.1
APP_PORT=8000

CAMPUSVISION_DATA_DIR=data

# Production face engine. Only InsightFace/ArcFace is supported.
FACE_ENGINE=insightface

DEFAULT_FRAME_INTERVAL_SEC=1.0

# Resource protection. Keep APP_HOST on loopback for local development.
# If APP_HOST is 0.0.0.0 / ::, requests that upload media or start indexing
# require X-CampusVision-API-Key and this value must be set.
CAMPUSVISION_API_KEY=
CAMPUSVISION_REQUIRE_API_KEY=false
CAMPUSVISION_MAX_VIDEO_UPLOAD_BYTES=536870912
CAMPUSVISION_MAX_QUERY_IMAGE_UPLOAD_BYTES=10485760
CAMPUSVISION_MAX_QUERY_IMAGES=5
CAMPUSVISION_MAX_INDEX_FRAMES=5000
